---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Screenshots from '../components/Screenshots.astro';
import DownloadSection from '../components/DownloadSection.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="NCOS Linux — Cosmic DE on an Arch base">
  <Hero />
  <Features />
  <Screenshots />
  <DownloadSection />

  <section class="section" id="news">
    <div class="container">
      <h2 class="section-title reveal">Latest news</h2>
      <p class="section-sub reveal">Releases, fixes and announcements.</p>
      <div class="news-grid">
        {
          posts.map((post) => (
            <a class="card reveal post" href={`/news/${post.id}/`}>
              <div class="meta">
                <span class={`pill pill-${post.data.tag}`}>{post.data.tag}</span>
                <time class="mono" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h3>{post.data.title}</h3>
              <p>{post.data.summary}</p>
            </a>
          ))
        }
      </div>
      <p class="all reveal"><a href="/news/">All news →</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .post {
    color: var(--text);
  }

  .post:hover {
    text-decoration: none;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .meta time {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .post h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .post p {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .all {
    margin-top: 1.6rem;
  }
</style>
