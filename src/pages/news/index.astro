---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="News — NCOS Linux">
  <section class="section page">
    <div class="container">
      <h1 class="section-title">News</h1>
      <p class="section-sub">Releases, fixes and announcements from the NCOS project.</p>
      <div class="timeline">
        {
          posts.map((post) => (
            <a class="entry" href={`/news/${post.id}/`}>
              <time class="mono" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <div class="body">
                <div class="head">
                  <h2>{post.data.title}</h2>
                  <span class={`pill pill-${post.data.tag}`}>{post.data.tag}</span>
                </div>
                <p>{post.data.summary}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: calc(var(--nav-height) + 4rem);
    min-height: 70vh;
  }

  .timeline {
    display: grid;
    gap: 1rem;
    max-width: 760px;
  }

  .entry {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.5rem;
    padding: 1.4rem;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    color: var(--text);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .entry:hover {
    text-decoration: none;
    border-color: rgba(139, 92, 246, 0.55);
    box-shadow: 0 0 26px rgba(139, 92, 246, 0.12);
  }

  .entry time {
    color: var(--muted);
    font-size: 0.8rem;
    padding-top: 0.25rem;
  }

  .head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .entry h2 {
    font-size: 1.15rem;
  }

  .entry p {
    color: var(--muted);
    font-size: 0.92rem;
    margin-top: 0.45rem;
  }

  @media (max-width: 560px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
