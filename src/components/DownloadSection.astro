---
import ReleaseInfo from './ReleaseInfo.astro';
import { SF_DOWNLOAD_URL, GITHUB_RELEASES_URL } from '../lib/release';
---

<section class="section" id="download">
  <div class="container">
    <div class="panel reveal">
      <div class="left">
        <h2 class="section-title">Get <span class="gradient-text">NCOS</span></h2>
        <p class="lede">
          One click, one ISO. The download starts immediately — flash it to a USB stick and
          follow the <a href="/wiki/Pre-Install/">installation guide</a>.
        </p>
        <a class="btn btn-primary big" href={SF_DOWNLOAD_URL}>
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 1v8.3L4.9 6.2 3.5 7.6 8 12.1l4.5-4.5-1.4-1.4L8 9.3V1H8ZM2 13h12v2H2v-2Z"></path>
          </svg>
          Download ISO
        </a>
        <p class="fineprint mono">
          direct download · no account needed · <a href={GITHUB_RELEASES_URL} target="_blank" rel="noopener">all releases →</a>
        </p>
        <div class="verify">
          <p class="verify-label mono">verify your download</p>
          <pre class="mono">sha256sum ncos-*.iso</pre>
        </div>
      </div>
      <div class="right">
        <ReleaseInfo />
      </div>
    </div>
  </div>
</section>

<style>
  .panel {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    background: linear-gradient(160deg, rgba(139, 92, 246, 0.09), rgba(45, 212, 191, 0.04)), var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 3rem;
  }

  .lede {
    color: var(--muted);
    margin: 0.75rem 0 1.8rem;
    max-width: 460px;
  }

  .big {
    font-size: 1.1rem;
    padding: 1rem 2.2rem;
  }

  .fineprint {
    margin-top: 1rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .verify {
    margin-top: 2rem;
  }

  .verify-label {
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .verify pre {
    background: #0c0c14;
    border: 1px solid var(--border-soft);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    color: var(--teal);
    overflow-x: auto;
  }

  .right {
    border-left: 1px dashed var(--border);
    padding-left: 3rem;
    align-self: center;
  }

  @media (max-width: 820px) {
    .panel {
      grid-template-columns: 1fr;
      padding: 2rem;
      gap: 2rem;
    }
    .right {
      border-left: none;
      border-top: 1px dashed var(--border);
      padding-left: 0;
      padding-top: 2rem;
    }
  }
</style>
