---

<section class="section" id="features">
  <div class="container">
    <h2 class="section-title reveal">Why <span class="gradient-text">NCOS</span>?</h2>
    <p class="section-sub reveal">Everything you like about Arch, minus the weekend you'd spend setting it up.</p>
    <div class="grid">
      {
        features.map((f) => (
          <article class="card reveal">
            <div class="icon">
              <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d={f.icon} />
              </svg>
            </div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .icon {
    display: inline-flex;
    padding: 0.6rem;
    border-radius: 10px;
    background: rgba(139, 92, 246, 0.12);
    color: var(--violet);
    margin-bottom: 1rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>
